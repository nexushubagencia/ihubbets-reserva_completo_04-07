APP_NAME="IHUB BETS V2"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=${APP_URL_RAILWAY}

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=${MYSQLHOST}
DB_PORT=${MYSQLPORT}
DB_DATABASE=${MYSQLDATABASE}
DB_USERNAME=${MYSQLUSER}
DB_PASSWORD=${MYSQLPASSWORD}

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@ihubbets.com"
MAIL_FROM_NAME="${APP_NAME}"

# === SPORTS DATA (BetsAPI - legado) ===
ASSETS_CDN_URL=https://assets.betsapi.com/v1/
TOKEN=
URL_BASE_BETS_API=https://api.b365api.com/v1/
URL_BASE_BETS_API_V2=https://api.b365api.com/v2/
BETS_API_TOKEN=

# === API-FOOTBALL (api-sports.io - novo) ===
APIFOOTBALL_API_KEY=
APIFOOTBALL_API_URL=https://v3.football.api-sports.io
API_FOOTBALL_PROXY=

# === FOOTBALL-DATA.ORG (v4 - fallback/testing) ===
FOOTBALLDATA_API_KEY=
FOOTBALLDATA_API_URL=https://api.football-data.org/v4

# === PIX PAYMENT GATEWAYS ===
PRIMEPAG_CLIENT_ID=
PRIMEPAG_CLIENT_SECRET=
PRIMEPAG_BASE_URL=https://api.primepag.com.br
PAGGUE_SIGNATURE=
PAGGUE_COMPANY_ID=
PAGGUE_CLIENT_KEY=
PAGGUE_CLIENT_SECRET=
PAGGUE_API_URL=https://api.paggue.com.br
